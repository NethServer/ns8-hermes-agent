#!/usr/bin/env python3

import json
import re
import subprocess
import sys

MIN_PODMAN_VERSION = (5, 1)
MIN_PODMAN_VERSION_TEXT = ".".join(str(part) for part in MIN_PODMAN_VERSION)


def parse_podman_version(raw_version: str) -> tuple[int, int, int]:
    match = re.match(r"\s*(\d+)\.(\d+)(?:\.(\d+))?", raw_version or "")
    if not match:
        raise RuntimeError(
            "Unable to determine the installed Podman version. "
            f"Expected a semantic version like '{MIN_PODMAN_VERSION_TEXT}.0', got: {raw_version!r}"
        )
    major = int(match.group(1))
    minor = int(match.group(2))
    patch = int(match.group(3) or 0)
    return (major, minor, patch)


json.load(sys.stdin)

result = subprocess.run(
    ["podman", "version", "--format", "{{.Client.Version}}"],
    check=True,
    capture_output=True,
    text=True,
)
version_text = result.stdout.strip()
version_tuple = parse_podman_version(version_text)

if version_tuple[:2] < MIN_PODMAN_VERSION:
    raise RuntimeError(
        "Podman 5.1 or newer is required by ns8-hermes-agent because the runtime uses volume "
        f"subpath mounts. Found Podman {version_text}. Upgrade Podman before installing the module."
    )
