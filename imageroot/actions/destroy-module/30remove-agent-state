#!/usr/bin/env python3

import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from action_logging import log_action_failure
from hermes_agent_state import list_known_agent_ids


def main():
    json.load(sys.stdin)

    for agent_id in list_known_agent_ids():
        subprocess.run(["runagent", "remove-agent-state", "--agent-id", str(agent_id)], check=True)


if __name__ == "__main__":
    try:
        main()
    except Exception as error:
        log_action_failure("destroy-module/30remove-agent-state", error)
        raise