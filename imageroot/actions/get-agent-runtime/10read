#!/usr/bin/env python3

import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from action_logging import log_action_failure
from hermes_agent_state import read_agents_from_state


def runtime_status(agent_id):
    # Report live systemd state only; the configured desired status remains in
    # per-agent metadata and is reconciled by configure-module.
    result = subprocess.run(
        ["systemctl", "--user", "is-active", "--quiet", f"hermes@{agent_id}.service"],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return "start" if result.returncode == 0 else "stop"


def main():
    request = json.load(sys.stdin)
    if not isinstance(request, dict):
        raise ValueError("get-agent-runtime input must be an object")

    json.dump(
        {
            "agents": [
                {
                    "id": agent_data["id"],
                    "runtime_status": runtime_status(agent_data["id"]),
                }
                for agent_data in read_agents_from_state()
            ]
        },
        fp=sys.stdout,
    )


if __name__ == "__main__":
    try:
        main()
    except Exception as error:
        log_action_failure("get-agent-runtime/10read", error)
        raise