#!/usr/bin/env python3

import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2] / "pypkg"))

from action_logging import log_action_failure


def main():
	json.load(sys.stdin)

	subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)


if __name__ == "__main__":
	try:
		main()
	except Exception as error:
		log_action_failure("configure-module/80reload-systemd", error)
		raise