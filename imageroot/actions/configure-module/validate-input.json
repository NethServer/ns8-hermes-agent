{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "configure-module input",
    "$id": "http://schema.nethserver.org/hermes-agent/configure-module-input.json",
    "description": "Configure hermes-agent",
    "examples": [],
    "type": "object",
    "additionalProperties": false,
    "required": [
        "agents"
    ],
    "properties": {
        "base_virtualhost": {
            "description": "Dashboard virtualhost for Hermes dashboard publishing. When set, authenticated requests to https://<host>/ route through the shared auth proxy to the assigned dashboard, and explicit /hermes-N/dashboard paths remain supported.",
            "anyOf": [
                {
                    "type": "string",
                    "maxLength": 0
                },
                {
                    "type": "string",
                    "format": "hostname",
                    "pattern": "\\.",
                    "not": {
                        "format": "ipv4"
                    }
                }
            ]
        },
        "workspace_virtualhost": {
            "description": "Workspace virtualhost for Hermes Workspace publishing. When set, authenticated requests to https://<host>/ route through the shared auth proxy to the assigned workspace, and explicit /hermes-N/workspace paths remain supported.",
            "anyOf": [
                {
                    "type": "string",
                    "maxLength": 0
                },
                {
                    "type": "string",
                    "format": "hostname",
                    "pattern": "\\.",
                    "not": {
                        "format": "ipv4"
                    }
                }
            ]
        },
        "user_domain": {
            "type": "string",
            "description": "Selected NS8 user domain used to authenticate dashboard and workspace logins when either shared virtualhost is enabled. Leave empty only when no shared auth route is published."
        },
        "lets_encrypt": {
            "type": "boolean",
            "description": "Request a Let's Encrypt certificate for each published Hermes dashboard or workspace virtualhost when routes are managed through Traefik."
        },
        "agents": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "id",
                    "name",
                    "role",
                    "status"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 30
                    },
                    "name": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^[A-Za-z ]+$"
                    },
                    "role": {
                        "type": "string",
                        "enum": [
                            "default",
                            "developer",
                            "marketing",
                            "sales",
                            "customer_support",
                            "social_media_manager",
                            "business_consultant",
                            "researcher"
                        ]
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "start",
                            "stop"
                        ]
                    },
                    "allowed_user": {
                        "type": "string",
                        "description": "Bare username from the selected NS8 user domain that is allowed to access this agent through the shared dashboard and workspace virtualhosts when publishing is enabled."
                    }
                }
            }
        }
    }
}