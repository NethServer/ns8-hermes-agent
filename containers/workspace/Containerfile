FROM ghcr.io/outsourc-e/hermes-workspace:latest
LABEL org.opencontainers.image.title="hermes-agent-workspace"
LABEL org.opencontainers.image.description="Hermes Workspace wrapper with a hermes-compatible runtime user"

USER root

RUN apt-get update && apt-get install -y --no-install-recommends passwd \
    && if ! getent group hermes >/dev/null; then groupadd --gid 10000 hermes; fi \
    && if ! getent passwd hermes >/dev/null; then useradd --uid 10000 --gid 10000 --home-dir /opt/data --create-home hermes; fi \
    && install -d -o hermes -g hermes /opt/data /opt/data/.hermes /opt/data/workspace \
    && rm -rf /var/lib/apt/lists/*

USER hermes
