FROM docker.io/nousresearch/hermes-agent:v2026.6.19
LABEL org.opencontainers.image.title="hermes-agent-hermes"
LABEL org.opencontainers.image.description="Thin wrapper around the upstream Hermes runtime image"

ENV VIRTUAL_ENV=/opt/hermes/.venv
ENV PATH="${VIRTUAL_ENV}/bin:${PATH}"

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    curl \
    gh \
    git \
    less \
    pip \
    python3-googleapi \
    python3-google-auth-oauthlib \
    vim

RUN pip install --no-cache-dir --break-system-packages \
    ddgs \
    pytesseract \
    pdf2image

RUN cd /opt/hermes && npx agent-browser install --with-deps

RUN cd /opt/hermes/web && npm install && npm run build
COPY favicon.ico /tmp/favicon.ico
RUN install -Dm0644 /tmp/favicon.ico /opt/hermes/hermes_cli/web_dist/favicon.ico \
    && install -Dm0644 /tmp/favicon.ico /opt/hermes/web/public/favicon.ico \
    && install -Dm0644 /tmp/favicon.ico /opt/hermes/website/static/img/favicon.ico \
    && rm -f /tmp/favicon.ico
RUN cd && npm install -g @qwen-code/qwen-code@latest

RUN apt-get clean autoclean && apt-get autoremove --yes && rm -rf /var/lib/{apt,dpkg,cache,log}/* && touch /var/lib/dpkg/status

# Preserve the upstream s6 runtime contract:
# - /init must remain PID 1 via the inherited ENTRYPOINT
# - cont-init runs as root and later drops supervised Hermes processes to the hermes user
RUN chown -R root:root /opt/hermes \
    && chmod -R a+rX /opt/hermes \
    && chmod -R a-w /opt/hermes \
    && mkdir -p /opt/data

USER root
